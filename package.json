{
  "name": "mission-control-bot",
  "version": "3.0.0",
  "description": "Always-online Telegram and Discord bot for Pyth Mission Control",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "docker:build": "docker build -t mission-control-bot .",
    "docker:run": "docker run --env-file .env mission-control-bot"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@notionhq/client": "^2.2.15",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.1",
    "google-auth-library": "^9.15.1",
    "google-spreadsheet": "^4.1.5",
    "grammy": "^1.41.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-fetch": "^2.6.13",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
